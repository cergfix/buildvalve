# Path to config file (for local dev from source; Docker images use /app/config/config.yml)
CONFIG_PATH=../config/config.yml

# Server port (default: 3000)
# PORT=3000

# CORS origin for frontend dev server (default: allow all)
# CORS_ORIGIN=http://localhost:5173

# Set to "production" to enable secure cookies
# NODE_ENV=production
